# Dobby AI Agent — Secrets
#
# Copy to .env and fill in the key for your chosen provider.
# .env is gitignored — never commit it.
#
# Priority: shell export > .env > dobby.conf > built-in defaults

# LLM Provider API key — not needed for local Ollama
#
# Groq
#API_KEY=gsk_...
# OpenRouter
#API_KEY=sk-or-...
# OpenAI      
#API_KEY=sk-...
# Anthropic          
#API_KEY=sk-ant-...       

# Email channel password (App Password, not your login password)
# Gmail: create at myaccount.google.com/apppasswords
#EMAIL_PASSWORD=your16charpassword

# Optional overrides (all have defaults in dobby.conf)
#MODEL=llama-3.3-70b-versatile
#PORT=8080
#LOG_LEVEL=warn
#WORKSPACE=~/.dobby
